{
  "name": "Vision-to-Graph-Enterprise-Env",
  "description": "Professional configuration for AI-powered graph extraction environment",
  
  // High-Level Port Management: Forces ports to be Public by default
  "forwardPorts": [3001, 5173],
  "portsAttributes": {
    "3001": {
      "label": "Express Backend API",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "5173": {
      "label": "Vite React Frontend",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },

  // Ensures that when the container starts, it respects these settings
  "customizations": {
    "codespaces": {
      "openFiles": [
        "frontend/src/hooks/useGraphUpload.js",
        "backend/index.js"
      ]
    }
  }
}